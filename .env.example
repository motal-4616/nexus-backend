# ── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?appName=<name>
MONGODB_URI=mongodb+srv://...

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────────────────────
# Your deployed frontend URL (e.g. https://nexus-app.netlify.app)
# Comma-separated for multiple: https://nexus.netlify.app,https://www.nexus-app.com
FRONTEND_URL=https://your-frontend.netlify.app

# ── Pusher ────────────────────────────────────────────────────────────────────
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=

# ── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Brevo (email) ──────────────────────────────────────────────────────────────
BREVO_API_KEY=
